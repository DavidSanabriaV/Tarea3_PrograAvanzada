@using Microsoft.AspNetCore.Identity
@using Tarea3.Models
@inject SignInManager<Persona> SignInManager
@inject UserManager<Persona> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link text-dark">Hola, @User.Identity?.Name</span>
    </li>
    <li class="nav-item">
        <a href="#" class="nav-link text-danger" id="logout-link">Cerrar sesión</a>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" href="/auth-frontend/login">Iniciar sesión</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/auth-frontend/register">Registrarse</a>
    </li>
}